#!/bin/bash
# Tao Lab pre-commit hook
# Warns when frontend source (.tsx/.css) is staged without rebuilding dist/
#
# Install: bash scripts/install_hooks.sh

STAGED_FRONTEND=$(git diff --cached --name-only | grep "tao_lab/ui/frontend/src/")

if [ -n "$STAGED_FRONTEND" ]; then
    STAGED_DIST=$(git diff --cached --name-only | grep "tao_lab/ui/frontend/dist/")
    if [ -z "$STAGED_DIST" ]; then
        echo ""
        echo "⚠️  Frontend source changed but dist/ not staged."
        echo ""
        echo "   Changed files:"
        echo "$STAGED_FRONTEND" | sed 's/^/     /'
        echo ""
        echo "   Fix:"
        echo "     cd tao_lab/ui/frontend && npm run build"
        echo "     git add tao_lab/ui/frontend/dist/"
        echo ""
        exit 1
    fi
fi
